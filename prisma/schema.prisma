generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================
// AUTH MODELS (NextAuth)
// ===================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  customer      Customer?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires     DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  ADMIN
  CUSTOMER
}

// ===================
// CUSTOMER & PROJECTS
// ===================

model Customer {
  id        String   @id @default(cuid())
  userId    String?  @unique
  name      String
  email     String   @unique
  company   String?
  phone     String?
  status    CustomerStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?    @relation(fields: [userId], references: [id])
  projects  Project[]
  payments Payment[]

  @@index([email])
  @@index([status])
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Project {
  id          String        @id @default(cuid())
  customerId  String
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  customer    Customer     @relation(fields: [customerId], references: [id])
  milestones  Milestone[]

  @@index([customerId])
  @@index([status])
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

model Milestone {
  id        String   @id @default(cuid())
  projectId String
  name      String
  status    String   @default("PENDING")
  dueDate   DateTime?
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ===================
// SERVICES & PRICING
// ===================

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  category    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tiers      PricingTier[]

  @@index([slug])
  @@index([isActive])
}

model PricingTier {
  id          String   @id @default(cuid())
  serviceId   String
  name        String
  description String?
  price       Float
  currency    String   @default("USD")
  features    String?  // JSON array
  isPopular   Boolean  @default(false)
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  service     Service  @relation(fields: [serviceId], references: [id])

  @@index([serviceId])
}

// ===================
// CONTENT
// ===================

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @db.Text
  image       String?
  author      String?
  tags        String?
  status      BlogStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model ContentFAQ {
  id          String   @id @default(cuid())
  question    String
  answer      String
  category    String
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([category])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  company   String?
  avatar    String?
  quote     String   @db.Text
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive])
}

// ===================
// PAYMENTS
// ===================

model Payment {
  id              String   @id @default(cuid())
  stripePaymentId String   @unique
  amount          Float
  currency        String   @default("usd")
  serviceName     String
  customerEmail   String
  customerName    String?
  status          PaymentStatus @default(PENDING)
  paymentType     PaymentType  @default(DEPOSIT)
  metadata        Json?
  createdAt       DateTime   @default(now())

  customer        Customer?  @relation(fields: [customerEmail], references: [email])

  @@index([status])
  @@index([customerEmail])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentType {
  DEPOSIT
  FULL
  SUBSCRIPTION
}

// ===================
// CONTACT
// ===================

model Contact {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  service   String
  message   String
  status    ContactStatus @default(NEW)
  source    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([createdAt])
  @@index([email])
  @@index([status])
}

enum ContactStatus {
  NEW
  CONTACTED
  CONVERTED
  ARCHIVED
}

// ===================
// PRICING SERVICE (New - from earlier)
// ===================

model PricingService {
  id            String   @id @default(cuid())
  serviceKey    String   @unique
  category      String
  unit          String
  isActive      Boolean  @default(true)
  displayOrder  Int      @default(0)
  priceMXN      Float
  priceEUR      Float
  priceUSD      Float
  discountYearly Float   @default(0.20)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  translations  PricingTranslation[]

  @@index([category])
  @@index([isActive])
}

model PricingTranslation {
  id                String        @id @default(cuid())
  pricingServiceId  String
  locale            String
  name              String
  shortDescription  String?
  features          String?

  pricingService    PricingService @relation(fields: [pricingServiceId], references: [id], onDelete: Cascade)

  @@unique([pricingServiceId, locale])
}

model ExchangeRate {
  id            String   @id @default(cuid())
  fromCurrency  String
  toCurrency    String
  rate          Float
  updatedAt     DateTime @updatedAt
  isActive      Boolean  @default(true)

  @@unique([fromCurrency, toCurrency])
}